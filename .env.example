# KairoFit Environment Variables
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.

# ============================================================
# Supabase
# https://supabase.com/dashboard/project/_/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Public - safe to expose in client
SUPABASE_SERVICE_ROLE_KEY=              # SECRET - server-side only, never expose

# ============================================================
# Anthropic (Kiro)
# https://console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY=                      # SECRET - server-side only

# ============================================================
# Stripe
# https://dashboard.stripe.com/apikeys
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # Public - safe to expose
STRIPE_SECRET_KEY=                      # SECRET - server-side only
STRIPE_WEBHOOK_SECRET=                  # From: stripe listen --print-secret
STRIPE_PRICE_ID_MONTHLY=               # $9.99/month price ID
STRIPE_PRICE_ID_ANNUAL=                # $79.99/year price ID

# ============================================================
# Upstash Redis (rate limiting)
# https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# PostHog (analytics)
# https://app.posthog.com/project/settings
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# Feature Flags
# Read CLAUDE.md before changing any of these defaults.
# Do NOT set to true until the feature is actually built.
# ============================================================

# Set to true when ready to charge users ($9.99/month or $79.99/year)
NEXT_PUBLIC_PAYWALL_ENABLED=false

# Set to true when social tables + social UI are built and tested
# Default is false - enabling an empty feature causes immediate runtime errors
NEXT_PUBLIC_SOCIAL_ENABLED=false

# Set to true when nutrition tracking is built (post-MVP)
NEXT_PUBLIC_NUTRITION_ENABLED=false

# Set to true when Apple Health + Google Fit integration is built (post-MVP)
NEXT_PUBLIC_WEARABLES_ENABLED=false

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# Note: Kiro persona toggle is a per-user database column
# (profiles.kiro_persona_enabled), NOT an environment variable.
# Do not add KIRO_PERSONA_ENABLED or NEXT_PUBLIC_KIRO_PERSONA_ENABLED here.
# ============================================================
