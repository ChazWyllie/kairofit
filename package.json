    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "serwist": "^9.0.0",
    "supabase": "^1.190.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.3",
    "vitest": "^2.0.0"
  }
