{
  "name": "kairofit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:kiro": "node scripts/kiro-lint.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --passWithNoTests",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration new",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --linked > src/types/supabase.generated.ts",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:fallbacks": "tsx scripts/generate-fallback-programs.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@anthropic-ai/sdk": "^0.30.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@stripe/stripe-js": "^9.0.0",
    "@supabase/ssr": "^0.4.1",
    "@supabase/supabase-js": "~2.50.0",
    "@tanstack/react-query": "^5.56.0",
    "@tanstack/react-query-devtools": "^5.56.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "ai": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "dexie": "^3.2.0",
    "dexie-react-hooks": "^1.1.7",
    "framer-motion": "^11.3.0",
    "glob": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "next-safe-action": "^7.0.0",
    "posthog-js": "^1.157.0",
    "posthog-node": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.0",
    "stripe": "^16.0.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0",
    "zustand": "^4.5.0"
